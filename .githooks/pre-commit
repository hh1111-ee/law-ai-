#!/usr/bin/env python3
"""Pre-commit hook: refuse commits that add sensitive files or known secret patterns.

Install by copying to `.git/hooks/pre-commit` (or run scripts/install_git_hook.*).
"""
import sys, subprocess, re

try:
    out = subprocess.check_output(['git', 'diff', '--cached', '--name-only'])
except subprocess.CalledProcessError:
    sys.exit(0)

files = out.decode(errors='ignore').splitlines()
blocked = []
for f in files:
    if re.search(r'(^|/)\.env($|\.)', f):
        blocked.append(f)
    if f.startswith('venv/') or f.startswith('.cloudflared/') or f.startswith('logs/') or f.startswith('__pycache__/'):
        blocked.append(f)

if blocked:
    print('Commit aborted: the following files are blocked by pre-commit policy:')
    for b in blocked:
        print('  -', b)
    print('\nIf you need to keep these files locally, add them to .gitignore or use `git rm --cached` to stop tracking.')
    sys.exit(1)

sys.exit(0)
